# Copy to .env.local and fill in. Never commit secrets.

# --- Database (local dev: docker compose up -d postgres) ---
DATABASE_URL="postgresql://vle:vle@localhost:55432/vle_dev"

# --- Auth.js v5 (used from lesson-03) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
# AUTH_URL is auto-detected in dev; set explicitly in prod.

# --- Email provider for magic links (lesson-03+) ---
# In dev we DO NOT need any email provider. Magic links are printed to the
# terminal running `npm run dev`. Set this to "console" (default in dev)
# or "resend" once you have an API key.
EMAIL_TRANSPORT="console"
RESEND_API_KEY=""
EMAIL_FROM="VLE <noreply@yourdomain.dev>"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
