# Copy to .env.local and fill in. Never commit secrets.

# --- Database (local dev: docker compose up -d postgres) ---
DATABASE_URL="postgresql://vle:vle@localhost:5432/vle_dev"

# --- Auth.js v5 (used from lesson-03) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# --- Email provider for magic links (lesson-03+) ---
# Resend is the default in lessons; swap providers freely.
RESEND_API_KEY=""
EMAIL_FROM="VLE <noreply@yourdomain.dev>"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
